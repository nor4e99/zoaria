# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.production
SECRET_KEY=your-very-long-random-secret-key-here
ALLOWED_HOSTS=yourdomain.railway.app,api.yourdomain.com
DEBUG=False

# ── Database (Railway provides DATABASE_URL automatically) ────────────────────
DATABASE_URL=postgresql://user:password@host:5432/zoaria
# Or individual vars:
# DB_NAME=zoaria
# DB_USER=postgres
# DB_PASSWORD=your-db-password
# DB_HOST=localhost
# DB_PORT=5432

# ── Redis (Railway provides REDIS_URL automatically) ─────────────────────────
REDIS_URL=redis://default:password@host:6379

# ── Email (Gmail SMTP example) ────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-app@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password

# ── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STANDARD_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# ── Frontend URL (for email links, CORS) ─────────────────────────────────────
FRONTEND_URL=https://yourdomain.vercel.app
CORS_ALLOWED_ORIGINS=https://yourdomain.vercel.app,https://www.yourdomain.com
